# 1. HTTP 80端口：自动跳转到HTTPS
server {
    listen 80;
    server_name luozihan.cn;
    return 301 https://$host$request_uri;
}

# 2. HTTPS 443端口：核心配置
server {
    listen 443 ssl;
    server_name luozihan.cn;

    ssl_certificate /etc/nginx/ssl/luozihan.cn/luozihan.cn_bundle.crt;
    ssl_certificate_key /etc/nginx/ssl/luozihan.cn/luozihan.cn.key;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;

    root /var/www/kawaii-homepage;
    index index.html;

    # luo 的 API（放在前面，优先匹配）
    location /luo/api/ {
        proxy_pass http://127.0.0.1:3000/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # luo 的独立主页
    location /luo/ {
        alias /var/www/kawaii-homepage/luo/;
        try_files $uri $uri/ =404;
    }

    # 主站
    location / {
        try_files $uri $uri/ =404;
    }

    # 主站 API
    location /api/ {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
    }

    location ~* \.json$ {
        expires -1;
        add_header Cache-Control "no-store, no-cache, must-revalidate, max-age=0";
    }
}
